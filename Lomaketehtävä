<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Contact & Feedback Form</title>

    <style>
        fieldset {
            border: 1px solid #888;
            padding: 10px 15px;
            margin-bottom: 20px;
        }
        legend {
            font-weight: normal;
        }

        table {
            border-collapse: collapse;
        }

        td {
            padding: 5px;
        }
    </style>
</head>

<body>

<form>
    <fieldset>
        <legend>Contact information</legend>

        <table>
            <tr>
                <td><label for="first-name">First name:</label></td>
                <td>
                    <input type="text" id="first-name" name="first-name">
                    Preferred contact method:
                </td>
            </tr>

            <tr>
                <td><label for="last-name">Last name:</label></td>
                <td>
                    <input type="text" id="last-name" name="last-name">
                    <label><input type="checkbox" name="preferred-contact" value="email"> Email</label>
                </td>
            </tr>

            <tr>
                <td><label for="email">Email:</label></td>
                <td>
                    <input type="email" id="email" name="email">
                    <label><input type="checkbox" name="preferred-contact" value="telephone"> Telephone</label>
                </td>
            </tr>

            <tr>
                <td><label for="telephone">Telephone:</label></td>
                <td><input type="tel" id="telephone" name="telephone"></td>
            </tr>
        </table>

    </fieldset>

    <fieldset>
        <legend>Feedback</legend>

        <table>
            <tr>
                <td><label for="subject">Message subject:</label></td>
                <td><input type="text" id="subject" name="subject" size="40"></td>
            </tr>

            <tr>
                <td><label for="message">Feedback:</label></td>
                <td><textarea id="message" name="message" rows="6" cols="50"></textarea></td>
            </tr>

            <tr>
                <td><label for="file">Attach a file:</label></td>
                <td><input type="file" id="file" name="file"></td>
            </tr>

            <tr>
                <td></td>
                <td><button type="submit">Send</button></td>
            </tr>
        </table>

    </fieldset>

</form>

</body>
</html>
